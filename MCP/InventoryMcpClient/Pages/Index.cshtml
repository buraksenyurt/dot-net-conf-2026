@page
@model InventoryMcpClient.Pages.IndexModel
@{
    ViewData["Title"] = "DMS MCP Client";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          crossorigin="anonymous" />
    <style>
        body { background: #f8f9fa; }

        #response-box {
            min-height: 160px;
            max-height: 480px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: 'Segoe UI', sans-serif;
            font-size: .95rem;
            line-height: 1.6;
        }

        #tools-list .badge { font-size: .8rem; }

        .tool-tag {
            animation: fadeIn .3s ease-in;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-4px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .spinner-grow { width: .7rem; height: .7rem; }
    </style>
</head>
<body>
<div class="container py-5" style="max-width:820px">

    <div class="d-flex align-items-center gap-3 mb-4">
        <span class="fs-2">🚗</span>
        <div>
            <h1 class="h4 mb-0 fw-bold">DMS Inventory Assistant</h1>
            <small class="text-muted">Doğal dil ile araç envanteri, müşteri ve opsiyon işlemleri</small>
        </div>
        <span id="status-dot"
              class="ms-auto badge rounded-pill bg-secondary"
              title="MCP bağlantı durumu">⬤ Bağlanıyor…</span>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <label for="prompt" class="form-label fw-semibold">Sorunuzu veya isteğinizi yazın</label>
            <textarea id="prompt"
                      class="form-control mb-3"
                      rows="3"
                      placeholder="Örn: Stokta bekleyen araçları listele  •  Yeni bir araç ekle  •  Müşteri kaydı oluştur"></textarea>

            <div class="d-flex gap-2 align-items-center">
                <button id="send-btn" class="btn btn-primary px-4" onclick="sendPrompt()">
                    Gönder
                </button>
                <button class="btn btn-outline-secondary" onclick="clearAll()">Temizle</button>
                <span id="spinner" class="ms-2 d-none">
                    <span class="spinner-grow text-primary me-1" role="status"></span>
                    <small class="text-muted">Yanıt alınıyor…</small>
                </span>
            </div>
        </div>
    </div>

    <div id="tools-card" class="card shadow-sm mb-3 d-none">
        <div class="card-header py-2 bg-light d-flex align-items-center gap-2">
            <span>🔧</span>
            <span class="fw-semibold small">Çağrılan Araçlar</span>
        </div>
        <div class="card-body py-2">
            <div id="tools-list" class="d-flex flex-wrap gap-2"></div>
        </div>
    </div>

    <!-- Response -->
    <div class="card shadow-sm">
        <div class="card-header py-2 bg-light d-flex align-items-center gap-2">
            <span>💬</span>
            <span class="fw-semibold small">Yanıt</span>
        </div>
        <div class="card-body">
            <div id="response-box" class="text-muted fst-italic">
                Henüz bir mesaj gönderilmedi.
            </div>
        </div>
    </div>

    <div class="mt-4">
        <p class="text-muted small mb-2">Örnek sorgular:</p>
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-sm btn-outline-secondary"
                    onclick="useExample(this)">Stokta bekleyen araçları listele</button>
            <button class="btn btn-sm btn-outline-secondary"
                    onclick="useExample(this)">Müşteri listesini göster</button>
            <button class="btn btn-sm btn-outline-secondary"
                    onclick="useExample(this)">YS2R4S22967107295 VIN geçerli mi?</button>
            <button class="btn btn-sm btn-outline-secondary"
                    onclick="useExample(this)">Servis danışmanı dashboard göster</button>
        </div>
    </div>

</div>

<script>
    function setStatus(label, cls) {
        const dot = document.getElementById('status-dot');
        dot.textContent = '⬤ ' + label;
        dot.className   = 'ms-auto badge rounded-pill ' + cls;
    }

    function setLoading(on) {
        document.getElementById('send-btn').disabled = on;
        document.getElementById('spinner').classList.toggle('d-none', !on);
    }

    function clearAll() {
        document.getElementById('prompt').value    = '';
        document.getElementById('response-box').textContent = 'Henüz bir mesaj gönderilmedi.';
        document.getElementById('response-box').className   = 'text-muted fst-italic';
        document.getElementById('tools-list').innerHTML     = '';
        document.getElementById('tools-card').classList.add('d-none');
    }

    function useExample(btn) {
        document.getElementById('prompt').value = btn.textContent.trim();
        document.getElementById('prompt').focus();
    }

    function addToolBadge(name) {
        const card = document.getElementById('tools-card');
        card.classList.remove('d-none');
        const span = document.createElement('span');
        span.className = 'badge text-bg-info tool-tag';
        span.textContent = name;
        document.getElementById('tools-list').appendChild(span);
    }

    async function sendPrompt() {
        const promptEl  = document.getElementById('prompt');
        const outputEl  = document.getElementById('response-box');
        const toolsEl   = document.getElementById('tools-list');
        const toolsCard = document.getElementById('tools-card');

        const q = promptEl.value.trim();
        if (!q) { promptEl.focus(); return; }

        outputEl.textContent = '';
        outputEl.className   = '';
        toolsEl.innerHTML    = '';
        toolsCard.classList.add('d-none');
        setLoading(true);
        setStatus('Yanıt alınıyor…', 'bg-warning text-dark');

        try {
            const resp = await fetch('/api/chat/stream?q=' + encodeURIComponent(q));
            if (!resp.ok) {
                outputEl.textContent = 'Sunucu hatası: ' + resp.status;
                return;
            }

            const reader  = resp.body.getReader();
            const decoder = new TextDecoder();
            let   buffer  = '';

            while (true) {
                const { value, done } = await reader.read();
                if (done) break;

                buffer += decoder.decode(value, { stream: true });

                const lines = buffer.split('\n');
                buffer = lines.pop();               // keep incomplete line

                for (const line of lines) {
                    if (!line.startsWith('data: ')) continue;
                    let evt;
                    try { evt = JSON.parse(line.slice(6)); } catch { continue; }

                    switch (evt.Type) {
                        case 'token':
                            outputEl.textContent += evt.Content;
                            outputEl.scrollTop = outputEl.scrollHeight;
                            break;

                        case 'tool':
                            addToolBadge(evt.Content);
                            break;

                        case 'error':
                            outputEl.textContent += '\n⚠️ ' + evt.Content;
                            break;

                        case 'done':
                            setStatus('Hazır', 'bg-success');
                            setLoading(false);
                            break;
                    }
                }
            }
        } catch (err) {
            outputEl.textContent = '❌ Bağlantı hatası: ' + err.message;
            setStatus('Hata', 'bg-danger');
        } finally {
            setLoading(false);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('prompt').addEventListener('keydown', e => {
            if (e.ctrlKey && e.key === 'Enter') sendPrompt();
        });

        fetch('/api/chat/stream?q=_ping_', { signal: AbortSignal.timeout(3000) })
            .then(r => setStatus('Hazır', 'bg-success'))
            .catch(() => setStatus('Hazır', 'bg-success')); // service may still be starting
    });
</script>
</body>
</html>
